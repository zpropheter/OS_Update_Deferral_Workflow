#!/bin/sh
#
# gdmf_overdue_minor_update_ea.sh
# Jamf Pro Extension Attribute (data type: String)
#
# Reads the JSON written by gdmf_deferral_tracker.sh and reports the
# "nextMinorUpdateDue" version - the same-major macOS release (e.g. 15.7.7
# while on 15.7.5) whose deferral window has expired and that this Mac
# still hasn't been forced to install. Returns "None" if no same-major
# update has aged out of the deferral window.
#
# See gdmf_overdue_major_update_ea.sh for the newer-major-version equivalent
# (e.g. flagging 26.0 while this Mac is still on 15.x).
#
# Optional override (e.g. Jamf policy parameter):
#   ./gdmf_overdue_minor_update_ea.sh /custom/path/to/status.json

statusFile="${1:-/var/log/gdmf_deferral_status.json}"

if [ ! -f "$statusFile" ]; then
	echo "<result>Unknown - status file not found</result>"
	exit 0
fi

version=$(plutil -extract nextMinorUpdateDue.version raw -o - "$statusFile" 2>/dev/null)

if [ -z "$version" ] || [ "$version" = "null" ]; then
	echo "<result>None</result>"
else
	echo "<result>${version}</result>"
fi
