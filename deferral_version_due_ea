#!/bin/sh
#
# gdmf_overdue_update_ea.sh
# Jamf Pro Extension Attribute (data type: String)
#
# Reads the JSON written by gdmf_deferral_tracker.sh and reports the
# "nextUpdateDue" version - the macOS release whose deferral window has
# expired and that this Mac still hasn't been forced to install. Returns
# "None" if nothing has aged out of the deferral window.
#
# Optional override (e.g. Jamf policy parameter):
#   ./gdmf_overdue_update_ea.sh /custom/path/to/status.json

statusFile="${1:-/var/log/gdmf_deferral_status.json}"

if [ ! -f "$statusFile" ]; then
	echo "<result>Unknown - status file not found</result>"
	exit 0
fi

version=$(plutil -extract nextUpdateDue.version raw -o - "$statusFile" 2>/dev/null)

if [ -z "$version" ] || [ "$version" = "null" ]; then
	echo "<result>None</result>"
else
	echo "<result>${version}</result>"
fi
