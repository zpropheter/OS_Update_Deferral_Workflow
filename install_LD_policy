#!/bin/sh
#
# install_gdmf_deferral_workflow.sh
#
# Fully self-contained installer - no other files to package or upload.
# Writes out the worker script (gdmf_deferral_tracker.sh) and the
# LaunchDaemon plist that runs it, then loads the daemon immediately.
# Deploy this single script (e.g. as one Jamf policy) and it does
# everything else on the target Mac. Run as root (sudo, or a Jamf
# policy, which already executes as root).
#
# Result once loaded:
#   - Runs immediately (RunAtLoad)
#   - Runs again on every subsequent restart
#   - Runs daily at 12:00 PM local time (StartCalendarInterval)
#   - On any run where nextMinorUpdateDue/nextMajorUpdateDue changed since
#     the last run, calls "jamf policy -event <trigger>" so a Jamf Pro
#     policy can react (force install, notify user, etc). Set up policies
#     in Jamf Pro with custom triggers "gdmfMinorUpdateDue" and
#     "gdmfMajorUpdateDue" (or override the trigger names below) scoped
#     to however you want minor updates vs major upgrades handled.
#
# Override the deferral window, output path, or Jamf triggers by editing
# the EnvironmentVariables block in the embedded plist below, then re-run
# this installer (it safely reloads if already installed).

set -eu

LABEL="com.updatedeferral.workflow"
SCRIPT_DEST="/usr/local/bin/gdmf_deferral_tracker.sh"
PLIST_DEST="/Library/LaunchDaemons/${LABEL}.plist"

if [ "$(id -u)" -ne 0 ]; then
	echo "Must be run as root (sudo)." >&2
	exit 1
fi

mkdir -p /usr/local/bin

# ---- Write the worker script ----
cat > "$SCRIPT_DEST" <<'WORKER_SCRIPT'
#!/bin/sh
#
# gdmf_deferral_tracker.sh
#
# Apple Silicon only. Meant to run once per day (LaunchDaemon / Jamf policy).
#
# 1. Reads this Mac's GDMF "Device ID" (from IOPlatformExpertDevice ->
#    IORegistryEntryName, e.g. J514cAP) - this is what GDMF's
#    SupportedDevices arrays list for arm64 hardware, NOT hw.model.
# 2. Pulls https://gdmf.apple.com/v2/pmv and finds every macOS release
#    whose SupportedDevices includes this Mac's Device ID.
# 3. For each match, computes days since PostingDate (Apple's release
#    date for that build). Because PostingDate never changes, this is
#    recalculated fresh each run - no state file needed for the counter
#    to be accurate day over day.
# 4. Writes a JSON summary: every release within the deferral window
#    (sorted most days-since-release to least, for easy table reference),
#    plus "nextMinorUpdateDue" and "nextMajorUpdateDue" - the newest same-
#    major and newest different-major release (respectively) that have
#    just aged OUT of the window, i.e. the updates your deferral policy
#    can no longer hold back. Kept separate because a minor update (e.g.
#    15.7.6) and a major upgrade (e.g. 26.0) are scoped to very different
#    Smart Groups/policies and shouldn't be collapsed into one value.
#
# 5. Compares nextMinorUpdateDue/nextMajorUpdateDue against the value
#    from the previous run (persisted in STATE_FILE). If either value
#    changed - including going from "nothing due" to "something due", or
#    from one overdue version to a newer one - it calls out to Jamf Pro
#    via a custom trigger (`jamf policy -event <trigger>`) so a policy can
#    react (e.g. force the install, notify the user, etc). Because this
#    runs on every boot (RunAtLoad) as well as daily at noon, a value that
#    changed while the Mac was off gets caught and reported the moment it
#    powers back on, not just at the next scheduled noon run.
#
# Override the deferral window per-run:
#   DEFERRAL_LIMIT_DAYS=60 ./gdmf_deferral_tracker.sh
#
# Override output path per-run:
#   OUTPUT_FILE=/tmp/test.json ./gdmf_deferral_tracker.sh
#
# Override the Jamf custom triggers / state file per-run:
#   JAMF_MINOR_TRIGGER=myMinorTrigger JAMF_MAJOR_TRIGGER=myMajorTrigger ./gdmf_deferral_tracker.sh

set -eu

DEFERRAL_LIMIT_DAYS="${DEFERRAL_LIMIT_DAYS:-90}"
OUTPUT_FILE="${OUTPUT_FILE:-/var/log/gdmf_deferral_status.json}"
ASSET_SET="${ASSET_SET:-AssetSets}"   # AssetSets = full release history; PublicAssetSets = latest per major only
GDMF_URL="https://gdmf.apple.com/v2/pmv"

# ---- Jamf Pro notification settings ----
JAMF_BIN="${JAMF_BIN:-/usr/local/bin/jamf}"
JAMF_MINOR_TRIGGER="${JAMF_MINOR_TRIGGER:-gdmfMinorUpdateDue}"
JAMF_MAJOR_TRIGGER="${JAMF_MAJOR_TRIGGER:-gdmfMajorUpdateDue}"
STATE_FILE="${STATE_FILE:-/var/log/gdmf_deferral_state.txt}"

# ---- Load the previous run's overdue versions, if any, for comparison ----
prevMinor=""
prevMajor=""
if [ -f "$STATE_FILE" ]; then
	prevMinor=$(awk -F= '$1 == "minor" { print $2 }' "$STATE_FILE")
	prevMajor=$(awk -F= '$1 == "major" { print $2 }' "$STATE_FILE")
fi

# ---- Guard: Apple Silicon only ----
if [ "$(arch)" != "arm64" ]; then
	echo "gdmf_deferral_tracker.sh only supports Apple Silicon. Exiting." >&2
	exit 1
fi

# ---- This Mac's GDMF device identifier ----
deviceID=$(ioreg -arc IOPlatformExpertDevice -d 1 | plutil -extract 0.IORegistryEntryName raw -o - -)
if [ -z "$deviceID" ]; then
	echo "Could not determine Device ID." >&2
	exit 1
fi

# ---- Currently installed OS, used to ignore stale/already-installed tracks ----
# GDMF keeps SupportedDevices entries alive for every release the hardware
# is capable of running, including old majors (14.x, 15.x, ...) and the
# exact version already installed. None of that is a pending update, so we
# only consider GDMF entries whose version is strictly newer than what's
# currently installed - a proper numeric compare, not a string compare
# (26.5.10 must sort after 26.5.2, string comparison would get that wrong).
currentVersion=$(sw_vers -productVersion)
currentMajor=$(printf '%s' "$currentVersion" | cut -d. -f1)

# Returns 0 (true) if $1 is a newer version than $2, comparing up to 4
# dot-separated numeric segments; missing segments are treated as 0.
version_gt() {
	n=1
	while [ "$n" -le 4 ]; do
		f1=$(printf '%s' "$1" | cut -d. -f"$n")
		f2=$(printf '%s' "$2" | cut -d. -f"$n")
		f1=${f1:-0}
		f2=${f2:-0}
		case "$f1" in ''|*[!0-9]*) f1=0 ;; esac
		case "$f2" in ''|*[!0-9]*) f2=0 ;; esac
		if [ "$f1" -gt "$f2" ]; then
			return 0
		elif [ "$f1" -lt "$f2" ]; then
			return 1
		fi
		n=$((n + 1))
	done
	return 1
}

# ---- Fetch GDMF feed to a real temp file ----
# (plutil against a literal "/dev/stdin" heredoc trips a permissions error
# under sudo - "stdin couldn't be opened because you don't have permission
# to view it" - so we write to disk once and point plutil at that file.)
tmpJSON=$(mktemp /tmp/gdmf.XXXXXX.plist)
trap 'rm -f "$tmpJSON"' EXIT

curl -sf "$GDMF_URL" -o "$tmpJSON" || { echo "Failed to fetch GDMF feed at ${GDMF_URL}" >&2; exit 1; }

count=$(plutil -extract "${ASSET_SET}.macOS" raw -o - "$tmpJSON")

nowEpoch=$(date -u +%s)

# Each qualifying entry gets buffered as "<daysSince>\t<jsonObject>" so it
# can be sorted numerically by daysSince before being written out.
recentList=""
nextMinorUpdateDue="null"
nextMinorUpdateDueDays=999999
nextMinorUpdateDueVersion=""
nextMajorUpdateDue="null"
nextMajorUpdateDueDays=999999
nextMajorUpdateDueVersion=""
recommendedScopeVersion="null"

i=0
while [ "$i" -lt "$count" ]; do
	supported=$(plutil -extract "${ASSET_SET}.macOS.${i}.SupportedDevices" json -o - "$tmpJSON")

	if printf '%s' "$supported" | grep -q "\"${deviceID}\""; then
		version=$(plutil -extract "${ASSET_SET}.macOS.${i}.ProductVersion" raw -o - "$tmpJSON")

		# Only consider versions actually newer than what's installed - this
		# is not a pending update otherwise, regardless of its posting date.
		if version_gt "$version" "$currentVersion"; then
			versionMajor=$(printf '%s' "$version" | cut -d. -f1)
			if [ "$versionMajor" = "$currentMajor" ]; then
				updateType="minor"
			else
				updateType="major"
			fi

			build=$(plutil -extract "${ASSET_SET}.macOS.${i}.Build" raw -o - "$tmpJSON")
			postingDate=$(plutil -extract "${ASSET_SET}.macOS.${i}.PostingDate" raw -o - "$tmpJSON")

			# PostingDate is "YYYY-MM-DD"
			postEpoch=$(date -u -j -f "%Y-%m-%d" "$postingDate" +%s 2>/dev/null) || postEpoch=""
			if [ -n "$postEpoch" ]; then
				daysSince=$(( (nowEpoch - postEpoch) / 86400 ))

				if [ "$daysSince" -le "$DEFERRAL_LIMIT_DAYS" ]; then
					recentList="${recentList}${daysSince}	{\"version\": \"${version}\", \"build\": \"${build}\", \"postingDate\": \"${postingDate}\", \"daysSinceRelease\": ${daysSince}, \"type\": \"${updateType}\"}
"
				elif [ "$updateType" = "minor" ] && [ "$daysSince" -lt "$nextMinorUpdateDueDays" ]; then
					nextMinorUpdateDueDays=$daysSince
					nextMinorUpdateDue="{\"version\": \"${version}\", \"build\": \"${build}\", \"postingDate\": \"${postingDate}\", \"daysSinceRelease\": ${daysSince}}"
					nextMinorUpdateDueVersion="$version"
				elif [ "$updateType" = "major" ] && [ "$daysSince" -lt "$nextMajorUpdateDueDays" ]; then
					nextMajorUpdateDueDays=$daysSince
					nextMajorUpdateDue="{\"version\": \"${version}\", \"build\": \"${build}\", \"postingDate\": \"${postingDate}\", \"daysSinceRelease\": ${daysSince}}"
					nextMajorUpdateDueVersion="$version"
				fi
			fi
		fi
	fi
	i=$((i + 1))
done

# Prefer flagging the minor update, since that's what's normally scoped for
# a forced install; fall back to the major upgrade if no minor is overdue.
if [ -n "$nextMinorUpdateDueVersion" ]; then
	recommendedScopeVersion="\"${nextMinorUpdateDueVersion}\""
elif [ -n "$nextMajorUpdateDueVersion" ]; then
	recommendedScopeVersion="\"${nextMajorUpdateDueVersion}\""
fi

# ---- Notify Jamf Pro if the overdue version changed since last run ----
# Fires on: nothing-due -> due, due -> a newer due version, or due -> clear.
notify_jamf() {
	trigger="$1"
	if [ -x "$JAMF_BIN" ]; then
		"$JAMF_BIN" policy -event "$trigger"
	else
		echo "jamf binary not found at ${JAMF_BIN}; skipping -event ${trigger}" >&2
	fi
}

if [ "$nextMinorUpdateDueVersion" != "$prevMinor" ]; then
	notify_jamf "$JAMF_MINOR_TRIGGER"
fi
if [ "$nextMajorUpdateDueVersion" != "$prevMajor" ]; then
	notify_jamf "$JAMF_MAJOR_TRIGGER"
fi

# ---- Persist this run's values so the next run can detect a change ----
{
	echo "minor=${nextMinorUpdateDueVersion}"
	echo "major=${nextMajorUpdateDueVersion}"
} > "$STATE_FILE"

# ---- Sort the deferral-window list by daysSinceRelease, most to least ----
recentEntries=""
first=1
if [ -n "$recentList" ]; then
	sortedRecent=$(printf '%s' "$recentList" | sort -t "$(printf '\t')" -k1,1 -nr)
	while IFS= read -r line; do
		[ -z "$line" ] && continue
		jsonPart=$(printf '%s\n' "$line" | cut -f2-)
		if [ "$first" -eq 1 ]; then
			recentEntries="
    ${jsonPart}"
			first=0
		else
			recentEntries="${recentEntries},
    ${jsonPart}"
		fi
	done <<SORTED
${sortedRecent}
SORTED
fi

cat > "$OUTPUT_FILE" <<JSON
{
  "deviceID": "${deviceID}",
  "currentVersion": "${currentVersion}",
  "checkedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "deferralLimitDays": ${DEFERRAL_LIMIT_DAYS},
  "updatesWithinDeferralWindow": [${recentEntries}
  ],
  "nextMinorUpdateDue": ${nextMinorUpdateDue},
  "nextMajorUpdateDue": ${nextMajorUpdateDue},
  "recommendedScopeVersion": ${recommendedScopeVersion}
}
JSON

cat "$OUTPUT_FILE"
WORKER_SCRIPT

chown root:wheel "$SCRIPT_DEST"
chmod 755 "$SCRIPT_DEST"

# ---- Write the LaunchDaemon plist ----
cat > "$PLIST_DEST" <<PLIST_FILE
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>${LABEL}</string>

	<key>ProgramArguments</key>
	<array>
		<string>${SCRIPT_DEST}</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Hour</key>
		<integer>12</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>EnvironmentVariables</key>
	<dict>
		<key>DEFERRAL_LIMIT_DAYS</key>
		<string>90</string>
		<key>OUTPUT_FILE</key>
		<string>/var/log/gdmf_deferral_status.json</string>
		<key>STATE_FILE</key>
		<string>/var/log/gdmf_deferral_state.txt</string>
		<key>JAMF_BIN</key>
		<string>/usr/local/bin/jamf</string>
		<key>JAMF_MINOR_TRIGGER</key>
		<string>gdmfMinorUpdateDue</string>
		<key>JAMF_MAJOR_TRIGGER</key>
		<string>gdmfMajorUpdateDue</string>
	</dict>

	<key>StandardOutPath</key>
	<string>/var/log/gdmf_deferral_tracker.log</string>
	<key>StandardErrorPath</key>
	<string>/var/log/gdmf_deferral_tracker.log</string>
</dict>
</plist>
PLIST_FILE

chown root:wheel "$PLIST_DEST"
chmod 644 "$PLIST_DEST"

# ---- Load (or reload) the daemon ----
if launchctl print "system/${LABEL}" >/dev/null 2>&1; then
	launchctl bootout system "$PLIST_DEST" 2>/dev/null || true
fi
launchctl bootstrap system "$PLIST_DEST"

echo "Installed ${SCRIPT_DEST} and loaded ${LABEL}."
echo "Runs now (RunAtLoad), daily at 12:00 PM, and on every restart."
